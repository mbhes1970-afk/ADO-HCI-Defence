# ============================================================
# ADO Platform — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ============================================================

# Required — set in Netlify Dashboard, never in codebase
ANTHROPIC_API_KEY=sk-ant-...

# Optional — operational Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Build config
VITE_BRAND=hci
VITE_APP_VERSION=1.0.0
VITE_CLASSIFICATION_DEFAULT=RESTRICTED
